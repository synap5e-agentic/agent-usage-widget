# Copy this file to ~/.config/agent-usage-widget/.env and fill in only
# the providers you actually use.

AGENT_USAGE_ENABLE_CLAUDE=0
AGENT_USAGE_ENABLE_CODEX=0
AGENT_USAGE_ENABLE_CURSOR=0

# Claude
AGENT_USAGE_CLAUDE_COOKIE=

# Codex
AGENT_USAGE_CODEX_AUTHORIZATION=
AGENT_USAGE_CODEX_COOKIE=

# Cursor
AGENT_USAGE_CURSOR_COOKIE=

# Optional overrides
# AGENT_USAGE_DB_DSN=postgresql://agent_usage:agent_usage@127.0.0.1:5433/agent_usage
# AGENT_USAGE_SERVICE_HOST=127.0.0.1
# AGENT_USAGE_SERVICE_PORT=8785
# AGENT_USAGE_CLAUDE_ORGANIZATION_ID=
# AGENT_USAGE_CLAUDE_ANONYMOUS_ID=
# AGENT_USAGE_CLAUDE_DEVICE_ID=
# AGENT_USAGE_CLAUDE_SESSION_KEY=
# AGENT_USAGE_CODEX_ACCOUNT_ID=
# AGENT_USAGE_CODEX_DEVICE_ID=
# AGENT_USAGE_CODEX_SESSION_ID=
# AGENT_USAGE_CODEX_OAI_SESSION_ID=
# AGENT_USAGE_CLAUDE_HEADERS_JSON={}
# AGENT_USAGE_CODEX_HEADERS_JSON={}
# AGENT_USAGE_CURSOR_HEADERS_JSON={}
